<% layout("layouts/boilerplates") %>

  <div class="show-wrapper">
    <div class="show-container">

      <div id="carouselExample" class="carousel slide">
        <div class="carousel-inner">

          <div class="carousel-item active">
            <img src="<%= listing.image.url %>" class="d-block w-100" alt="Listing Image">
            <div class="heart" onclick="toggleWishlist(this)">❤</div>
          </div>

          <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511" class="d-block w-100" alt="Image 2">
            <div class="heart" onclick="toggleWishlist(this)">❤</div>
          </div>

          <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85" class="d-block w-100" alt="Image 3">
            <div class="heart" onclick="toggleWishlist(this)">❤</div>
          </div>

          <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2" class="d-block w-100" alt="Image 4">
            <div class="heart" onclick="toggleWishlist(this)">❤</div>
          </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
        </button>
      </div>

      <div class="details-section">
        <h1 class="listing-title">
          <%= listing.title %>
        </h1>

        <p class="price-tag">
          ₹ <%= listing.price.toLocaleString("en-IN") %>
            <span style="color: darkturquoise;">/ night</span>
        </p>

        <p>
          <i>
            <b>
              Owned by :
              <%= listing.author ? listing.author.username : "Unknown User" %>
            </b>
          </i>
        </p>

        <p class="desc">
          <%= listing.description %>
        </p>

        <p class="location">
          📍 <%= listing.location %>, <%= listing.country %>
        </p>

        <% if (currentUser && listing.author && currentUser._id.equals(listing.author._id)) { %>
          <div class="btn-area">
            <a href="/listings/<%= listing._id %>/edit" class="btn edit">Edit</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE"
              onsubmit="return confirmDeleteListing()">
              <button class="btn delete" type="submit">Delete</button>
            </form>
          </div>
          <% } %>
      </div>

      <% if (currentUser) { %>
        <div class="review-box">
          <h3 class="review-box-title">Leave a Review</h3>

          <form id="reviewForm" action="/listings/<%= listing._id %>/reviews" method="POST" novalidate>
            <div class="rating-wrapper mb-3">
              <fieldset class="starability-slot" id="ratingGroup">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="" checked
                  aria-label="No rating." />

                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>

                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>

                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>

                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>

                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>

                <span class="starability-focus-ring"></span>
              </fieldset>

              <p id="ratingMessage" class="rating-message">Select a rating</p>

              <div class="rating-error" id="ratingError" style="display:none;">
                Please select a rating 🥴
              </div>
            </div>

            <div class="comment-box mb-3">
              <label class="form-label">Comment</label>
              <textarea id="reviewComment" name="review[comment]" class="form-control" rows="4"
                placeholder="Write your experience..."></textarea>

              <div class="comment-error" id="commentError" style="display:none;">
                Please add some comments for review 🥴
              </div>
            </div>

            <button type="submit" class="btn-review">Submit Review</button>
          </form>
        </div>
        <% } else { %>
          <div class="review-box review-login-box">
            <h3 class="review-login-title">Login Required</h3>
            <p class="review-login-text">Please sign in to write a review for this stay.</p>
            <a href="/login" class="btn-review login-review-btn">Sign In to Review</a>
          </div>
          <% } %>

    </div>

    <div class="bottom-info-grid">

      <% if (currentUser) { %>
        <div class="reviews-bottom">
          <h2 class="reviews-heading">Guest Reviews</h2>

          <% if (listing.reviews && listing.reviews.length> 0) { %>
            <div class="reviews-list">
              <% listing.reviews.forEach((review)=> { %>
                <div class="review-item">
                  <div class="stars">
                    <% for (let i=1; i <=review.rating; i++) { %>
                      ★
                      <% } %>
                  </div>

                  <p>
                    <%= review.comment %>
                  </p>

                  <p class="review-user">
                    Reviewed by :
                    <span>
                      <%= review.author ? review.author.username : "Anonymous User" %>
                    </span>
                  </p>

                  <% if (currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                    <div class="review-actions">
                      <a href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit" class="edit-review-btn">
                        Edit
                      </a>

                      <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirmDeleteReview()">
                        <button class="delete-review-btn" type="submit">Delete</button>
                      </form>
                    </div>
                    <% } %>
                </div>
                <% }) %>
            </div>
            <% } else { %>
              <p class="no-review-text">No reviews yet. Be the first one to review this place!</p>
              <% } %>
        </div>
        <% } %>

          <div class="map-section">
            <div class="map-card">
              <h2 class="map-heading">📍 Location Map</h2>
              <p class="map-subtitle">See where this place is located</p>

              <% const hasGeometry=listing && listing.geometry && listing.geometry.coordinates &&
                listing.geometry.coordinates.length===2 && !(listing.geometry.coordinates[0]===0 &&
                listing.geometry.coordinates[1]===0); %>

                <% if (hasGeometry) { %>
                  <div id="map"></div>
                  <% } else { %>
                    <div class="alert alert-warning">
                      Map location is not available for this listing.
                    </div>
                    <% } %>
            </div>
          </div>

    </div>
  </div>

  <link href="https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.js"></script>

  <script type="application/json" id="listing-map-data">
<%- JSON.stringify({
  mapToken: mapToken,
  hasGeometry:
    listing &&
    listing.geometry &&
    listing.geometry.coordinates &&
    listing.geometry.coordinates.length === 2 &&
    !(listing.geometry.coordinates[0] === 0 && listing.geometry.coordinates[1] === 0),
  coordinates:
    listing &&
    listing.geometry &&
    listing.geometry.coordinates
      ? listing.geometry.coordinates
      : [],
  title: listing.title || "",
  locationText: (listing.location || "") + ", " + (listing.country || "")
}) %>
</script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const mapContainer = document.getElementById("map");
      const dataEl = document.getElementById("listing-map-data");

      if (!mapContainer || !dataEl || typeof mapboxgl === "undefined") return;

      let listingData;

      try {
        listingData = JSON.parse(dataEl.textContent);
      } catch (err) {
        console.error("Map data parse error:", err);
        return;
      }

      if (!listingData.hasGeometry) return;

      const coordinates = listingData.coordinates;
      const listingTitle = listingData.title;
      const listingLocation = listingData.locationText;

      if (!Array.isArray(coordinates) || coordinates.length !== 2) return;

      mapboxgl.accessToken = listingData.mapToken;

      function getMapStyle() {
        if (document.body.classList.contains("dark-mode")) {
          return "mapbox://styles/mapbox/dark-v11";
        }
        return "mapbox://styles/mapbox/streets-v12";
      }

      const map = new mapboxgl.Map({
        container: "map",
        style: getMapStyle(),
        center: coordinates,
        zoom: 10
      });

      const navControl = new mapboxgl.NavigationControl();
      map.addControl(navControl, "top-right");

      const popup = new mapboxgl.Popup({ offset: 45 }).setHTML(
        "<div class='map-popup-body'>" +
        "<h1 class='map-popup-title'>" + listingTitle + "</h1>" +
        "<h1 class='map-popup-location'>" + listingLocation + "</h1>" +
        "</div>"
      );

      const marker = new mapboxgl.Marker({ color: "red" })
        .setLngLat(coordinates)
        .setPopup(popup)
        .addTo(map);

      let currentTheme = document.body.classList.contains("dark-mode") ? "dark" : "light";

      function updateMapTheme() {
        const nextTheme = document.body.classList.contains("dark-mode") ? "dark" : "light";

        if (nextTheme === currentTheme) return;

        currentTheme = nextTheme;
        map.setStyle(getMapStyle());

        map.once("style.load", function () {
          marker.addTo(map);
        });
      }

      const observer = new MutationObserver(function () {
        updateMapTheme();
      });

      observer.observe(document.body, {
        attributes: true,
        attributeFilter: ["class"]
      });
    });
  </script>