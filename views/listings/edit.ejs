<% layout("layouts/boilerplates") %>

  <div class="edit-wrapper">
    <div class="edit-box">

      <div class="edit-header">
        <h2>📝 Edit Listing</h2>
        <p>Update your property details below</p>
      </div>

      <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" class="needs-validation" novalidate
        enctype="multipart/form-data">

        <div class="form-group">
          <label>Title 🏠</label>
          <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
          <div class="valid-feedback">
            Title looks perfect 👍
          </div>
          <div class="invalid-feedback">
            Please enter a valid property title.
          </div>
        </div>

        <div class="form-group">
          <label>Description 📝</label>
          <textarea name="listing[description]" class="form-control" required><%= listing.description %></textarea>
          <div class="valid-feedback">
            Description added successfully ✅
          </div>
          <div class="invalid-feedback">
            Description must be at least 10 characters.
          </div>
        </div>

        <div class="form-group">
          <label>Current Image 🖼️</label><br>
          <img src="<%= listing.image.url %>" alt="Current Listing Image"
            style="width: 220px; height: 150px; object-fit: cover; border-radius: 12px; margin-bottom: 12px;">
        </div>

        <div class="form-group">
          <label>Choose New Image 🖼️</label>
          <input type="file" name="listingImage" class="form-control"
            accept="image/png, image/jpeg, image/jpg, image/webp">
          <div class="invalid-feedback">
            Please choose a valid image file.
          </div>
        </div>

        <div class="custom-row">
          <div class="form-group">
            <label>Price 💰</label>
            <input type="number" name="listing[price]" value="<%= listing.price %>" min="0" class="form-control"
              required>
            <div class="valid-feedback">
              Price looks good 💸
            </div>
            <div class="invalid-feedback">
              Price must be greater than 0.
            </div>
          </div>

          <div class="form-group">
            <label>Country 🌍</label>
            <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
            <div class="valid-feedback">
              Country selected ✔
            </div>
            <div class="invalid-feedback">
              Please enter country name.
            </div>
          </div>
        </div>

        <div class="form-group">
          <label>Location 📍</label>
          <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
          <div class="valid-feedback">
            Location updated successfully 📍
          </div>
          <div class="invalid-feedback">
            Please enter location.
          </div>




          <div class="form-group">
            <label>Category 🏷️</label>
            <select name="listing[category]" class="form-control" required>
              <option value="Trending" <%=listing.category==="Trending" ? "selected" : "" %>>Trending</option>
              <option value="Rooms" <%=listing.category==="Rooms" ? "selected" : "" %>>Rooms</option>
              <option value="Iconic City" <%=listing.category==="Iconic City" ? "selected" : "" %>>Iconic City</option>
              <option value="Mountains" <%=listing.category==="Mountains" ? "selected" : "" %>>Mountains</option>
              <option value="Castles" <%=listing.category==="Castles" ? "selected" : "" %>>Castles</option>
              <option value="Amazing Pools" <%=listing.category==="Amazing Pools" ? "selected" : "" %>>Amazing Pools
              </option>
              <option value="Arctic" <%=listing.category==="Arctic" ? "selected" : "" %>>Arctic</option>
              <option value="Farms" <%=listing.category==="Farms" ? "selected" : "" %>>Farms</option>
              <option value="Camping" <%=listing.category==="Camping" ? "selected" : "" %>>Camping</option>
              <option value="Beach" <%=listing.category==="Beach" ? "selected" : "" %>>Beach</option>
              <option value="Treehouse" <%=listing.category==="Treehouse" ? "selected" : "" %>>Treehouse</option>
              <option value="Camped" <%=listing.category==="Camped" ? "selected" : "" %>>Camped</option>
              <option value="Hotel" <%=listing.category==="Hotel" ? "selected" : "" %>>Hotel</option>
              <option value="Apartment" <%=listing.category==="Apartment" ? "selected" : "" %>>Apartment</option>
              <option value="Sunset" <%=listing.category==="Sunset" ? "selected" : "" %>>Sunset</option>
              <option value="Parking" <%=listing.category==="Parking" ? "selected" : "" %>>Parking</option>
              <option value="Wishlist" <%=listing.category==="Wishlist" ? "selected" : "" %>>Wishlist</option>
              <option value="Kitchen" <%=listing.category==="Kitchen" ? "selected" : "" %>>Kitchen</option>
              <option value="Location" <%=listing.category==="Location" ? "selected" : "" %>>Location</option>
            </select>
          </div>
        </div>

        <button class="btn-save" type="submit">
          Update Listing
        </button>

      </form>

    </div>
  </div>