           <% layout("layouts/boilerplates") %> 

  <div class="add-wrapper">
    <div class="add-box">

      <div class="add-header">
        <h2>➕ Add New Listing</h2>
        <p>Enter your property details below</p>
      </div>

      <form action="/listings" method="POST" class="needs-validation" novalidate >
        <div class="input-group " >
          <label>Title 🏠</label> 
          <!-- <input required name="listing[title]" class="form-control" type="text" placeholder="Enter title"> -->
           <input required name="listing[title]" type="text"  placeholder="Enter title">
        </div>

        <div class="input-group">
          <label>Description 📝</label>
          <textarea required name="listing[description]" placeholder="Enter description"></textarea>
        </div>

        <div class="input-group" >
          <label>Image URL 🖼️</label>
          <input  required name="listing[image][url]" type="text" placeholder="Enter image URL">
        </div>

        <div class="row">
          <div class="input-group">
            <label>Price 💰</label>
            <input required name="listing[price]" type="number" placeholder="Enter price">
          </div>

          <div class="input-group">
            <label>Country 🌍</label>
            <input required name="listing[country]" type="text" placeholder="Enter country">
          </div>
        </div>

        <div class="input-group">
          <label>Location 📍</label>
          <input required name="listing[location]" type="text" placeholder="Enter location">
        </div>

        <button class="btn-add">ADD LISTING</button>

      </form>
    </div>
  </div>  



